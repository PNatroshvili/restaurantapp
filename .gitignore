# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios

# Android - keep source tracked, exclude build artifacts and keystores
android/build/
android/.gradle/
android/app/build/
android/app/.cxx/
android/app/release.keystore
android/app/debug.keystore
android/local.properties
android/.idea/

# Sensitive / generated
keystore_base64.txt
tmp_b64.txt
build-log.txt
desktop.ini
*.pdf
.idea/
